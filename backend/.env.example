# ─────────────────────────────────────────────────────────────
# MediScan Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — only commit .env.example
# ─────────────────────────────────────────────────────────────

# ── App Settings ─────────────────────────────────────────────
APP_NAME=MediScan
APP_VERSION=1.0.0
DEBUG=False                         # Set True only during local development
ALLOWED_ORIGINS=["http://localhost:3000"]
# ── Supabase ─────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
SUPABASE_URL=https://npbdtkfnieytnzbazmly.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5wYmR0a2ZuaWV5dG56YmF6bWx5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUzNzk3MjAsImV4cCI6MjA5MDk1NTcyMH0.eFvqEHpjTj5qN3bqoUmxwv8M3OZRTED1hwixf3Ig0XE
# ── Upstash Redis ─────────────────────────────────────────────
# Get these from: upstash.com → your database → Details
REDIS_URL=rediss://default:gQAAAAAAATV_AAIncDI3ZTk2OGRkOTk0M2U0OGY4OWE5NWY0ZGI5ZmFmM2M0MXAyNzkyMzE@fresh-shepherd-79231.upstash.io:6379
REDIS_PASSWORD=

# ── HuggingFace ───────────────────────────────────────────────
# Get from: huggingface.co → Settings → Access Tokens (free)
HUGGINGFACE_API_KEY=hf_your_token_here

# ── LibreTranslate ────────────────────────────────────────────
# Using the free public instance (rate limited but free)
# You can self-host on HuggingFace Spaces for no limits
LIBRETRANSLATE_URL=https://libretranslate.com
LIBRETRANSLATE_API_KEY=your-libretranslate-key  # Optional for public instance

# ── OpenFDA ───────────────────────────────────────────────────
# OpenFDA is completely free — no key required
# But adding a key increases rate limit from 40/min to 240/min
# Get free key from: open.fda.gov/apis/authentication
OPENFDA_API_KEY=   

# ── OCR Settings ─────────────────────────────────────────────
OCR_CONFIDENCE_THRESHOLD=0.6        # Below this score → fallback to TrOCR
MAX_IMAGE_SIZE_MB=10                # Reject images larger than this
